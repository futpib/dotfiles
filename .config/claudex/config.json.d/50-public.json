{
  "packages": [
    "nodejs",
    "deno",
    "bun",
    "rustup",
    "libyaml",
    "yarn",
    "python",
    "uv",
    "lynx",
    "curl-impersonate",
    "yt-dlp",
    "nix",
    "corepack",
    "npm",
    "nvm",
    "claugrep-git"
  ],
  "volumes": [
    "~/.local/bin/"
  ],
  "env": {
    "PATH": "~/.cargo/bin:~/.local/bin/:~/.local/share/npm-global/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
  },
  "hooks": true,
  "profiles": [
    "github-cli"
  ],
  "profileDefinitions": {
    "glab": {
      "packages": [
        "glab"
      ],
      "volumes": [
        "~/.config/glab-cli/"
      ]
    },
    "github-cli": {
      "packages": [
        "github-cli"
      ],
      "volumes": [
        "~/.config/gh/"
      ]
    },
    "rbenv": {
      "packages": [
        "rbenv"
      ],
      "volumes": [
        "~/.rbenv/"
      ],
      "env": {
        "PATH": "~/.rbenv/shims/"
      }
    }
  }
}

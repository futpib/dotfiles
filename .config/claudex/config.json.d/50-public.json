{
  "packages": [
    "nodejs",
    "deno",
    "bun",
    "rustup",
    "libyaml",
    "yarn",
    "python",
    "uv",
    "lynx",
    "curl-impersonate",
    "yt-dlp",
    "nix",
    "corepack",
    "npm",
    "nvm",
    "claugrep-git",
    "unzip",
    "graphviz"
  ],
  "volumes": [
    "~/.local/bin/"
  ],
  "env": {
    "PATH": "~/.cargo/bin:~/.local/bin/:~/.local/share/npm-global/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
  },
  "hooks": true,
  "profiles": [
    "github-cli"
  ],
  "launcherOverrides": {
    "claude": {
      "args": [
        "--effort",
        "max",
        "--thinking-display",
        "summarized"
      ],
      "env": {
        "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
      }
    }
  },
  "claudeSettings": {
    "showThinkingSummaries": true
  },
  "profileDefinitions": {
    "adb": {
      "packages": [
        "android-tools"
      ],
      "hostPorts": [
        5037
      ]
    },
    "flutter": {
      "packages": [
        "fvm",
        "dart"
      ],
      "volumes": [
        "~/fvm",
        "~/.pub-cache"
      ]
    },
    "flutter-android": {
      "packages": [
        "android-sdk",
        "android-sdk-platform-tools",
        "android-sdk-build-tools",
        "android-sdk-cmdline-tools-latest",
        "android-platform",
        "jdk21-openjdk"
      ],
      "volumes": [
        "~/Android/Sdk"
      ]
    },
    "flutter-desktop": {
      "packages": [
        "cmake",
        "ninja",
        "pkg-config",
        "clang",
        "gtk3"
      ]
    },
    "glab": {
      "packages": [
        "glab"
      ],
      "volumes": [
        "~/.config/glab-cli/"
      ]
    },
    "github-cli": {
      "packages": [
        "github-cli"
      ],
      "volumes": [
        "~/.config/gh/"
      ]
    },
    "rbenv": {
      "packages": [
        "rbenv",
        "ruby-build"
      ],
      "volumes": [
        "~/.rbenv/"
      ],
      "env": {
        "PATH": "~/.rbenv/shims/"
      }
    },
    "lightpanda": {
      "packages": [
        "curl"
      ],
      "env": {
        "PATH": "/opt/lightpanda/bin"
      },
      "rootInitCommands": [
        "mkdir -p /opt/lightpanda/bin",
        "curl -fsSL -o /opt/lightpanda/bin/lightpanda https://github.com/lightpanda-io/browser/releases/download/nightly/lightpanda-x86_64-linux",
        "chmod +x /opt/lightpanda/bin/lightpanda"
      ]
    },
    "agent-browser": {
      "packages": [
        "nodejs",
        "npm",
        "chromium"
      ],
      "volumes": [
        "~/.agent-browser/",
        "~/.cache/ms-playwright/"
      ],
      "env": {
        "npm_config_prefix": "~/.local/share/npm-global",
        "PATH": "~/.local/share/npm-global/bin"
      },
      "userInitCommands": [
        "npm install -g agent-browser"
      ],
      "userStartupCommands": [
        "[ -d ~/.cache/ms-playwright ] && [ -n \"$(ls -A ~/.cache/ms-playwright 2>/dev/null)\" ] || agent-browser install"
      ]
    }
  }
}

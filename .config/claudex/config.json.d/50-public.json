{
  "packages": [
    "nodejs",
    "deno",
    "bun",
    "rustup",
    "libyaml",
    "yarn",
    "python",
    "uv",
    "lynx",
    "curl-impersonate",
    "yt-dlp",
    "nix",
    "corepack",
    "npm",
    "nvm",
    "claugrep-git",
    "unzip",
    "graphviz"
  ],
  "volumes": [
    "~/.local/bin/"
  ],
  "env": {
    "PATH": "~/.cargo/bin:~/.local/bin/:~/.local/share/npm-global/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
  },
  "hooks": true,
  "profiles": [
    "github-cli"
  ],
  "claudeArgs": [
    "--effort",
    "max"
  ],
  "claudeEnv": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  },
  "claudeSettings": {
    "showThinkingSummaries": true
  },
  "profileDefinitions": {
    "adb": {
      "packages": [
        "android-tools"
      ],
      "hostPorts": [
        5037
      ]
    },
    "flutter": {
      "packages": [
        "fvm",
        "dart"
      ],
      "volumes": [
        "~/fvm",
        "~/.pub-cache"
      ]
    },
    "glab": {
      "packages": [
        "glab"
      ],
      "volumes": [
        "~/.config/glab-cli/"
      ]
    },
    "github-cli": {
      "packages": [
        "github-cli"
      ],
      "volumes": [
        "~/.config/gh/"
      ]
    },
    "rbenv": {
      "packages": [
        "rbenv",
        "ruby-build"
      ],
      "volumes": [
        "~/.rbenv/"
      ],
      "env": {
        "PATH": "~/.rbenv/shims/"
      }
    }
  }
}
